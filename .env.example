# Copy to .env and fill values.
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
BOCHA_API_KEY=your_bocha_api_key_here

# Optional tuning
# USER_PROFILE_PATH=user_profile.md
# LLM_TEMPERATURE=1.3
# PLAN_REPLAN_MAX_STEPS=100
# PLAN_REPLAN_RETRY_COUNT=3
# PLAN_CONTINUOUS_FAILURE_LIMIT=3
# TASK_CANCEL_COMMAND=取消任务
# ASSISTANT_PERSONA=

# Feishu long connection (optional; auto-enabled when app credentials are set)
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Feishu calendar sync (optional; requires Feishu credentials)
FEISHU_CALENDAR_ID=

# Scheduled planner final-result target (optional; requires Feishu credentials)
PROACTIVE_REMINDER_TARGET_OPEN_ID=
