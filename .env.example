# Copy to .env and fill values.
DEEPSEEK_API_KEY=your_deepseek_api_key_here
BOCHA_API_KEY=your_bocha_api_key_here

# Optional tuning
# USER_PROFILE_PATH=user_profile.md
# LLM_TEMPERATURE=1.3
# PLAN_REPLAN_MAX_STEPS=100
# PLAN_REPLAN_RETRY_COUNT=3
# PLAN_CONTINUOUS_FAILURE_LIMIT=3
# TASK_CANCEL_COMMAND=取消任务
# ASSISTANT_PERSONA=

# Feishu long connection (optional)
FEISHU_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Feishu calendar sync (optional)
FEISHU_CALENDAR_SYNC_ENABLED=false
FEISHU_CALENDAR_ID=

# Proactive reminder (optional, requires FEISHU_ENABLED=true)
PROACTIVE_REMINDER_ENABLED=false
PROACTIVE_REMINDER_TARGET_OPEN_ID=

# Compatibility fallback (optional)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=
